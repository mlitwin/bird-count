{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "baseUrl": "./src",
        "paths": {
            "model/*": ["model/*"],
            "store/*": ["store/*"],
            "common/*": ["common/*"],
            "data/*": ["data/*"]
        },
        "allowJs": false,
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx"
    },
    "include": ["src"],
    "references": []
}
