{
  "name": "bird-count-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.mjs --external:@aws-sdk/* --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "test": "vitest run",
    "generate": "node ../../bird-count-schema/scripts/generate-ts.mjs src/generated/types.ts"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.678.0",
    "@aws-sdk/lib-dynamodb": "^3.678.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.17.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
